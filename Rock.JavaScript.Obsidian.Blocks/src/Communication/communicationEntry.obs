<template>
    <Panel v-if="!config.isHidden"
           :title="config.title ?? 'New Communication'"
           titleIconCssClass="fa fa-comment-o"
           type="block">

        <template v-if="statusLabel" #subheaderRight>
            <HighlightLabel labelType="default">{{ statusLabel }}</HighlightLabel>
        </template>

        <template #default>
            <div v-if="!areResultsShown">
                <PanelNavigationBar v-model="selectedMediumEntityTypeGuidOrEmptyString"
                                    :isFirstSelectedByDefault="true"
                                    :items="mediums" />

                <KeepAlive v-if="selectedMediumEntityTypeGuidOrEmptyString && config.communication && config.mediumOptions">
                    <Email v-if="areEqual(selectedMediumEntityTypeGuidOrEmptyString, EntityType.CommunicationMediumEmail)"
                           :communication="config.communication"
                           :isFullMode="isFullMode"
                           :mediumOptions="(config.mediumOptions as CommunicationEntryEmailMediumOptionsBag)"
                           @saved="onSentOrSaved"
                           @sent="onSentOrSaved" />

                    <Sms v-else-if="areEqual(selectedMediumEntityTypeGuidOrEmptyString, EntityType.CommunicationMediumSms)"
                         :isFullMode="isFullMode" />

                    <PushNotification v-else-if="areEqual(selectedMediumEntityTypeGuidOrEmptyString, EntityType.CommunicationMediumPushNotification)"
                                      :isFullMode="isFullMode" />

                    <div v-else>
                        Unknown communication medium (Guid: {{ selectedMediumEntityTypeGuidOrEmptyString }}).
                        Options are
                        <ul>
                            <li>{{ EntityType.CommunicationMediumEmail }}</li>
                            <li>{{ EntityType.CommunicationMediumSms }}</li>
                            <li>{{ EntityType.CommunicationMediumPushNotification }}</li>
                        </ul>
                    </div>
                </KeepAlive>
            </div>

            <div v-else
                 id="pnlResult"
                 ref="sentResultsDiv"
                 class="js-pnl-result">

                <NotificationBox alertType="success">{{ resultMessage }}</NotificationBox>
                <br />
                <a :href="viewCommunicationUrl">View Communication</a>
            </div>
        </template>
    </Panel>
</template>

<script setup lang="ts">
    import { computed, ref } from "vue";
    import PanelNavigationBar from "./CommunicationEntry/panelNavigationBar.partial.obs";
    import { Nullable } from "./CommunicationEntry/types.partial";
    import HighlightLabel from "@Obsidian/Controls/highlightLabel.obs";
    import NotificationBox from "@Obsidian/Controls/notificationBox.obs";
    import Panel from "@Obsidian/Controls/panel.obs";
    import { CommunicationStatus, CommunicationStatusDescription } from "@Obsidian/Enums/Communication/communicationStatus";
    import { onConfigurationValuesChanged, useConfigurationValues, useReloadBlock } from "@Obsidian/Utility/block";
    import { CommunicationEntryInitializationBox } from "@Obsidian/ViewModels/Blocks/Communication/CommunicationEntry/communicationEntryInitializationBox";
    import { CommunicationEntrySendResponseBag } from "@Obsidian/ViewModels/Blocks/Communication/CommunicationEntry/communicationEntrySendResponseBag";
    import { ListItemBag } from "@Obsidian/ViewModels/Utility/listItemBag";
    import Email from "./CommunicationEntry/communicationMediumEmail.partial.obs";
    import Sms from "./CommunicationEntry/communicationMediumSms.partial.obs";
    import PushNotification from "./CommunicationEntry/communicationMediumPushNotification.partial.obs";
    import { EntityType } from "@Obsidian/SystemGuids/entityType";
    import { CommunicationEntryEmailMediumOptionsBag } from "@Obsidian/ViewModels/Blocks/Communication/CommunicationEntry/communicationEntryEmailMediumOptionsBag";
    import { areEqual } from "@Obsidian/Utility/guid";

    const config = useConfigurationValues<CommunicationEntryInitializationBox>();
    const reloadBlock = useReloadBlock();

    defineProps();

    //#region Values

    const areResultsShown = ref<boolean>(false);
    const isFullMode = ref<boolean>(config.isFullMode);
    const statusLabel = ref<Nullable<string>>(config.communication ? getStatusLabel(config.communication.status) : null);
    const sentResultsDiv = ref<HTMLElement | undefined>();
    const mediums = computed<ListItemBag[]>(() => config.mediums ?? []);
    const selectedMediumEntityTypeGuidOrEmptyString = ref<string>("");
    const resultMessage = ref<Nullable<string>>("");
    const viewCommunicationUrl = ref<string>(window.location.href);

    //#endregion

    //#region Computed Values

    //#endregion

    //#region Functions

    /** Gets the label for a communication status. */
    function getStatusLabel(status: CommunicationStatus): string {
        if (status === CommunicationStatus.Transient) {
            return "Draft";
        }
        else {
            return CommunicationStatusDescription[status];
        }
    }

    //#endregion

    //#region Event Handlers

    /** Event handler for the communication being sent. */
    function onSentOrSaved(value: CommunicationEntrySendResponseBag): void {
        if (value.redirectToViewMode) {
            const url = new URL(window.location.href);
            const queryParams = url.searchParams;

            queryParams.set("CommunicationId", (value.communicationId ?? "") + "");
            viewCommunicationUrl.value = url.href;
        }

        statusLabel.value = getStatusLabel(value.communicationStatus ?? CommunicationStatus.Draft);
        resultMessage.value = value.message;
        areResultsShown.value = true;
    }

    //#endregion

    //#region Watchers

    //#endregion

    //#region Hooks

    //#endregion

    onConfigurationValuesChanged(reloadBlock);

</script>