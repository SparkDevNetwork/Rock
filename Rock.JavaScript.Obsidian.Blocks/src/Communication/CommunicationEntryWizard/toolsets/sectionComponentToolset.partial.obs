<template>
    <ComponentToolsetBase @complete="$emit('complete')"
                          @delete="$emit('delete')">
        <AccordionGroup>
            <Accordion title="Row Settings">
                <BackgroundColorTool :modelValue="selectedComponent.componentElement" />
                <BorderComboTool :modelValue="selectedComponent.componentElement" />
            </Accordion>

            <Accordion title="Columns">
                {{ columnElements.length }}
            </Accordion>
        </AccordionGroup>
    </ComponentToolsetBase>
</template>

<script setup lang="ts">
    import { PropType, ref, watch } from "vue";
    import ComponentToolsetBase from "./componentToolsetBase.partial.obs";
    import Accordion from "../controls/accordion.partial.obs";
    import AccordionGroup from "../controls/accordionGroup.partial.obs";
    import BackgroundColorTool from "../tools/backgroundColorTool.partial.obs";
    import BorderComboTool from "../tools/borderComboTool.partial.obs";
    import { EditorComponent } from "../types.partial";

    const props = defineProps({
        selectedComponent: {
            type: Object as PropType<EditorComponent>,
            required: true
        }
    });

    defineEmits<{
        (e: "complete"): void;
        (e: "delete"): void;
    }>();

    // #region Values

    const backgroundColor = ref<string>(props.selectedComponent.componentElement.style.backgroundColor ?? "");
    const columnElements = ref<HTMLElement[]>([...props.selectedComponent.componentElement.querySelectorAll(".dropzone")].map(e => <HTMLElement>e));

    // #endregion

    // #region Watchers

    watch(() => props.selectedComponent, () => {
        backgroundColor.value = props.selectedComponent?.componentElement.style.backgroundColor ?? "";
    });

    // #endregion
</script>