<template>
    <LengthTypeProperty v-bind="baseProps"
                        property="font-size"
                        @update:styleSheetValues="onStyleSheetValuesUpdated" />
</template>

<script setup lang="ts">
    import { PropType } from "vue";
    import { CSSStyleDeclarationKebabKey, Include } from "./types.partial";
    import { getDerived, standardProps, useStandardProps } from "./utils.partial";
    import LengthTypeProperty from "./lengthTypeProperty.partial.obs";

    type FontSizeProperty = Include<
        CSSStyleDeclarationKebabKey,
        "font-size"
    >;

    const props = defineProps({
        ...standardProps,

        styleSheetValues: {
            type: Object as PropType<Partial<Record<FontSizeProperty, string>> | undefined>,
        },

        label: {
            type: String as PropType<string>,
            default: "Font Size" as const
        }
    });

    const baseProps = useStandardProps(props);

    const emit = defineEmits<{
        (e: "update:styleSheetValues", value: Partial<Record<FontSizeProperty, string>>): void;
    }>();

    // #region Event Handlers

    function onStyleSheetValuesUpdated(values: Partial<Record<CSSStyleDeclarationKebabKey, string>>): void {
        emit(
            "update:styleSheetValues",
            getDerived<CSSStyleDeclarationKebabKey, FontSizeProperty>(values, [
                "font-size"
            ])
        );
    }

    // #endregion Event Handlers
</script>
