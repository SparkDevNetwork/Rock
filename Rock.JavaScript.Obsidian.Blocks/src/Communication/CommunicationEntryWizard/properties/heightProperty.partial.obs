<template>
    <LengthTypePropertyBase v-bind="lengthProps"
                            :element="element"
                            property="height"
                            @change="$emit('change', $event)" />
</template>

<script setup lang="ts">
    import { PropType } from "vue";
    import LengthTypePropertyBase from "./lengthTypePropertyBase.partial.obs";
    import { ShorthandPropertyMode } from "./types.partial";
    import { standardLengthProps, useStandardLengthProps } from "./utils.partial";

    const props = defineProps({
        ...standardLengthProps,

        element: {
            type: Object as PropType<HTMLElement>,
            required: true
        },

        label: {
            type: String as PropType<string>,
            default: "Height" as const
        },

        min: {
            type: Number as PropType<number>,
            default: 0
        },

        max: {
            type: Number as PropType<number>,
            default: 700
        },

        mode: {
            type: String as PropType<ShorthandPropertyMode>,
            default: "rangeSlider" as const
        }
    });

    const lengthProps = useStandardLengthProps(props);

    defineEmits<{
        (e: "change", value: string): void;
    }>();
</script>