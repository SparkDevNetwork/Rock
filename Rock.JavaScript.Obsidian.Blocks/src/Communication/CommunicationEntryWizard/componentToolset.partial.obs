<template>
    <div>
        <TitleComponentToolset v-if="componentTypeName === 'title'"
                               :componentElement="componentElement"
                               @complete="$emit('complete')"
                               @delete="$emit('delete')" />

        <VideoComponentToolset v-else-if="componentTypeName === 'video'"
                               :componentElement="componentElement"
                               @complete="$emit('complete')"
                               @delete="$emit('delete')" />

        <ButtonComponentToolset v-else-if="componentTypeName === 'button'"
                                :componentElement="componentElement"
                                @complete="$emit('complete')"
                                @delete="$emit('delete')" />

        <TextComponentToolset v-else-if="componentTypeName === 'text'"
                              :componentElement="componentElement"
                              @complete="$emit('complete')"
                              @delete="$emit('delete')" />

        <DividerComponentToolset v-else-if="componentTypeName === 'divider'"
                                 :componentElement="componentElement"
                                 @complete="$emit('complete')"
                                 @delete="$emit('delete')" />

        <AdaptiveMessageComponentToolset v-else-if="componentTypeName === 'message'"
                                         :componentElement="componentElement"
                                         @complete="$emit('complete')"
                                         @delete="$emit('delete')" />

        <ImageComponentToolset v-else-if="componentTypeName === 'image'"
                               :componentElement="componentElement"
                               @complete="$emit('complete')"
                               @delete="$emit('delete')" />

        <CodeComponentToolset v-else-if="componentTypeName === 'code'"
                              :componentElement="componentElement"
                              @complete="$emit('complete')"
                              @delete="$emit('delete')" />

        <RsvpComponentToolset v-else-if="componentTypeName === 'rsvp'"
                              :componentElement="componentElement"
                              @complete="$emit('complete')"
                              @delete="$emit('delete')" />

        <div v-else>Unknown component type: {{ componentTypeName }}.</div>
    </div>
</template>

<script setup lang="ts">
    import { computed, PropType } from "vue";
    import AdaptiveMessageComponentToolset from "./toolsets/adaptiveMessageComponentToolset.partial.obs";
    import ButtonComponentToolset from "./toolsets/buttonComponentToolset.partial.obs";
    import CodeComponentToolset from "./toolsets/codeComponentToolset.partial.obs";
    import DividerComponentToolset from "./toolsets/dividerComponentToolset.partial.obs";
    import ImageComponentToolset from "./toolsets/imageComponentToolset.partial.obs";
    import RsvpComponentToolset from "./toolsets/rsvpComponentToolset.partial.obs";
    import TextComponentToolset from "./toolsets/textComponentToolset.partial.obs";
    import TitleComponentToolset from "./toolsets/titleComponentToolset.partial.obs";
    import VideoComponentToolset from "./toolsets/videoComponentToolset.partial.obs";
    import { EditorComponentTypeName } from "./types.partial";
    import { getComponentTypeName } from "./utils.partial";

    const props = defineProps({
        componentElement: {
            type: Object as PropType<HTMLElement>,
            required: true
        }
    });

    // #region Computed Values

    const componentTypeName = computed<EditorComponentTypeName>(() => {
        return getComponentTypeName(props.componentElement);
    });

    // #endregion Computed Values

    defineEmits(["complete", "delete"]);
</script>