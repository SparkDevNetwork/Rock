<template>
    <div class="form-group">
        <InlineSwitch v-model="hasBorder"
                      :label="label" />
    </div>

    <TransitionVerticalCollapse>
        <div v-if="hasBorder">
            <BorderColorTool ref="borderColorTool"
                             :element="element"
                             @elementBorderColorUpdated="onElementBorderColorUpdated" />

            <BorderWidthTool ref="borderWidthTool"
                             :element="element"
                             @elementBorderWidthUpdated="onElementBorderWidthUpdated" />
        </div>
    </TransitionVerticalCollapse>
</template>

<script setup lang="ts">
    import { PropType, ref, watch } from "vue";
    import BorderColorTool from "./borderColorTool.partial.obs";
    import BorderWidthTool from "./borderWidthTool.partial.obs";
    import InlineSwitch from "@Obsidian/Controls/inlineSwitch.obs";
    import TransitionVerticalCollapse from "@Obsidian/Controls/transitionVerticalCollapse.obs";

    const props = defineProps({
        element: {
            type: Object as PropType<HTMLElement>,
            required: true
        },
        label: {
            type: String as PropType<string>,
            default: "Border"
        }
    });

    // #region Values

    const hasBorder = ref<boolean>(!!(props.element.style.border || props.element.style.borderColor || props.element.style.borderWidth));
    const borderColorTool = ref<InstanceType<typeof BorderColorTool> | undefined>();
    const borderWidthTool = ref<InstanceType<typeof BorderWidthTool> | undefined>();

    // #endregion

    // #region Event Handlers

    function onElementBorderColorUpdated(): void {
        if (props.element.style.borderColor) {
            if (!props.element.style.borderStyle) {
                // Ensure the element has a border style if a border color is specified.
                props.element.style.borderStyle = "solid";
            }
        }
        else {
            props.element.style.borderStyle = "";
        }
    }

    function onElementBorderWidthUpdated(): void {
        if (props.element.style.borderWidth) {
            if (!props.element.style.borderStyle) {
                // Ensure the element has a border style if a border color is specified.
                props.element.style.borderStyle = "solid";
            }
        }
        else {
            props.element.style.borderStyle = "";
        }
    }

    // #endregion

    // #region Watchers

    watch(hasBorder, () => {
        if (!hasBorder.value) {
            // Clear the border properties when "Border" is switched off.
            if (borderColorTool.value) {
                borderColorTool.value.borderColor = "";
            }

            if (borderWidthTool.value) {
                borderWidthTool.value.borderWidth = 0;
            }
        }
    });

    // #endregion
</script>
