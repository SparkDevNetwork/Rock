<template>
    <div class="label-designer">
        <Panel title="Label Designer"
               hasFullscreen>
            <template #headerActions>
                <LabelDimensionsButton v-model="labelSize" />
            </template>

            <div class="panel-body-fill" style="display: flex;">
                <Menu />

                <Editor v-model:labelFields="labelFields"
                        :labelSize="labelSize" />
            </div>

            <template #footerActions>
                <RockButton btnType="primary">Save</RockButton>
            </template>
        </Panel>
    </div>
</template>

<style scoped>
.label-designer {
    --menu-bar-height: 37px;
}

.panel-body-fill {
    margin: calc(var(--panel-body-padding) * -1);
}

.container {
    max-width: 720px;
}

.container > :deep(.konvajs-content) {
    border: 1px solid black;
    background-color: white;
}
</style>

<script setup lang="ts">
    import Editor from "./LabelDesigner/editor.partial.obs";
    import LabelDimensionsButton from "./LabelDesigner/labelDimensionsButton.partial.obs";
    import Menu from "./LabelDesigner/menu.partial.obs";
    import Panel from "@Obsidian/Controls/panel.obs";
    import RockButton from "@Obsidian/Controls/rockButton.obs";
    import { computed, ref } from "vue";
    import { LabelBag, LabelFieldBag, LabelFieldType, Size } from "./LabelDesigner/types.partial";
    import { newGuid } from "@Obsidian/Utility/guid";

    const labelSize = computed<Size>({
        get() {
            return {
                width: label.value.width,
                height: label.value.height
            };
        },
        set(value) {
            label.value.width = value.width;
            label.value.height = value.height;
        }
    });

    const labelFields = computed<LabelFieldBag[]>({
        get() {
            return label.value.fields ?? [];
        },
        set(value) {
            label.value.fields = value;
        }
    });

    const label = ref<LabelBag>({
        width: 4.0,
        height: 2.0,
        fields: [
            {
                guid: newGuid(),
                fieldType: LabelFieldType.Rectangle,
                subFieldType: 0,
                isIncludedOnPreview: true,
                left: 2,
                top: 0.25,
                width: 1,
                height: 1,
                rotationAngle: 0,
                customDataValue: "",
                configurationValues: {}
            },
            {
                guid: newGuid(),
                fieldType: LabelFieldType.Text,
                subFieldType: 0,
                isIncludedOnPreview: true,
                left: 1,
                top: 0.25,
                width: 1,
                height: 0.5,
                rotationAngle: 0,
                customDataValue: "",
                configurationValues: {}
            },
        ]
    });
</script>
