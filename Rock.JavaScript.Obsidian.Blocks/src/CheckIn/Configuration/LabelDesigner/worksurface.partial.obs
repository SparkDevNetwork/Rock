<template>
    <div class="worksurface-container">
        <div ref="fontLoaderElement" class="font-loader"></div>
        <div ref="containerElement"
             class="worksurface">
        </div>
    </div>
</template>

<style>
@import url('https://fonts.googleapis.com/css2?family=Roboto+Condensed:ital,wght@0,100..900;1,100..900&family=Roboto:ital,wght@0,100;0,300;0,400;0,500;0,700;0,900;1,100;1,300;1,400;1,500;1,700;1,900&display=swap');
</style>

<style scoped>
.worksurface-container {
    position: relative;
    margin: 12px;
}

.font-loader {
    width: 0;
    height: 0;
    overflow: hidden;
}

.worksurface {
    display: flex;
    justify-content: center;
    align-items: center;
    background-color: var(--theme-white);
    border-radius: 12px;
    overflow: hidden;
}
</style>

<script setup lang="ts">
    import Konva from "@Obsidian/Libs/konva";
    import { onBeforeUnmount, onMounted, PropType, ref, watch } from "vue";
    import { TransformHelper } from "./transformHelper.partial";
    import { LabelUndoManager } from "./undoManager.partial";
    import { createShapeForFieldType, getOffsetForPixel, getPixelForOffset, updateShapeFromField, useNodeDragBoundFunc } from "./utils.partial";

    const props = defineProps({
        labelManager: {
            type: Object as PropType<LabelUndoManager>,
            required: true
        },

        showGrid: {
            type: Boolean as PropType<boolean>,
            required: true
        },

        snapToGrid: {
            type: Boolean as PropType<boolean>,
            required: true
        }
    });

    /* Grid size in 1/n fractions of an inch. */
    const gridSnapFraction = 4;

    // /** Minimum snap position in 1/n fractions of an inch. */
    // const minimumSnapFraction = 32;

    const containerElement = ref<HTMLDivElement | undefined>();
    const fontLoaderElement = ref<HTMLDivElement | undefined>();
    let stage: Konva.Stage | undefined;
    let transformHelper: TransformHelper | undefined;
    let nodeLayer: Konva.Layer | undefined;
    let nodeDragBoundFunc: ((this: Konva.Node, pos: Konva.Vector2d) => Konva.Vector2d) | undefined;
    const gridLayer = new Konva.Layer();
    const pixelsPerInch = 72 * window.devicePixelRatio;


    /**
     * Draws the grid lines onto the grid layer. This will clear the layer
     * if no grid lines should be displayed.
     */
    function drawGridLines(): void {
        gridLayer.destroyChildren();

        if (!stage || !props.showGrid) {
            return;
        }

        const width = stage.width();
        const height = stage.height();
        const gridStepSize = 1.0 / gridSnapFraction;

        for (let step = gridStepSize; step < props.labelManager.current.value.width; step += gridStepSize) {
            gridLayer.add(new Konva.Line({
                x: getPixelForOffset(step),
                points: [0, 0, 0, height],
                stroke: "rgba(128, 128, 128, 0.1)",
                strokeWidth: 1
            }));
        }

        for (let step = gridStepSize; step < props.labelManager.current.value.height; step += gridStepSize) {
            gridLayer.add(new Konva.Line({
                y: getPixelForOffset(step),
                points: [0, 0, width, 0],
                stroke: "rgba(128, 128, 128, 0.1)",
                strokeWidth: 1
            }));
        }

        gridLayer.draw();
    }

    function snapPixel(pixel: number): number {
        let offset = getOffsetForPixel(pixel);

        if (props.showGrid && props.snapToGrid) {
            offset = 1.0 / gridSnapFraction * Math.round(gridSnapFraction * offset);
        }
        // else {
        //     offset = 1.0 / minimumSnapFraction * Math.floor(minimumSnapFraction * offset);
        // }

        return getPixelForOffset(offset);
    }

    function createOrUpdateNodes(): void {
        if (!nodeDragBoundFunc || !nodeLayer) {
            return;
        }

        for (const field of props.labelManager.current.value.fields ?? []) {
            const node = nodeLayer.children.find(n => n.id() === field.guid);
            let shape = (node instanceof Konva.Shape || node instanceof Konva.Group) ? node : undefined;

            if (shape) {
                // Try to update the node, if we can't update it then remove
                // it so it gets re-created.
                if (updateShapeFromField(shape, field)) {
                    continue;
                }
                else {
                    shape.remove();
                    shape = undefined;
                }
            }

            if (!shape) {
                shape = createShapeForFieldType(field.fieldType);

                // Shouldn't happen, but skip the node.
                if (!shape) {
                    console.error(`Could not create node for field type ${field.fieldType}.`);
                    continue;
                }

                shape.setAttrs({
                    id: field.guid,
                    draggable: true,
                    dragBoundFunc: nodeDragBoundFunc
                });

                nodeLayer.add(shape);
            }

            shape.setAttrs({
                x: getPixelForOffset(field.left),
                y: getPixelForOffset(field.top),
                width: getPixelForOffset(field.width),
                height: getPixelForOffset(field.height)
            });

            updateShapeFromField(shape, field);
        }
    }

    async function waitForFonts(timeout: number): Promise<void> {
        if (!document.fonts || !fontLoaderElement.value) {
            return;
        }

        const timeoutAt = Date.now() + timeout;
        const requiredFonts = ["Roboto", "Roboto Condensed"];
        const fonts = await new Promise<FontFaceSet>(r => document.fonts.ready.then(r));

        for (const fontName of requiredFonts) {
            const d = document.createElement("div");
            d.style.fontFamily = fontName;
            d.innerText = "text";
            fontLoaderElement.value.append(d);
        }

        while (Date.now() < timeoutAt) {
            const readyFonts = [...fonts]
                .filter(f => f.status === "loaded")
                .map(f => f.family.replace(/["']/g, ""));
            const readyRequiredFonts = requiredFonts.filter(req => readyFonts.includes(req));

            if (readyRequiredFonts.length === requiredFonts.length) {
                break;
            }

            await new Promise<void>(r => setTimeout(r, 50));
        }

        fontLoaderElement.value.innerHTML = "";
    }

    onMounted(async () => {
        if (!containerElement.value) {
            return;
        }

        // Wait up to 2.5 seconds for fonts to load.
        await waitForFonts(2500);

        stage = new Konva.Stage({
            container: containerElement.value,
            width: props.labelManager.current.value.width * pixelsPerInch,
            height: props.labelManager.current.value.height * pixelsPerInch,
        });

        nodeDragBoundFunc = useNodeDragBoundFunc(stage, snapPixel);

        nodeLayer = new Konva.Layer();
        stage.add(nodeLayer);

        stage.add(gridLayer);
        drawGridLines();

        createOrUpdateNodes();

        const transformerLayer = new Konva.Layer();
        stage.add(transformerLayer);

        var tr = new Konva.Transformer({
            nodes: [],
            rotationSnaps: [0, 90, 180, 270],
            rotationSnapTolerance: 45,
            rotateAnchorOffset: 25,
            flipEnabled: false,
            keepRatio: false

        });

        transformerLayer.add(tr);

        transformHelper = new TransformHelper(stage, tr, snapPixel);

        // clicks should select/deselect shapes
        stage.on("click tap", function (e) {
            let target: Konva.Node | null = e.target;

            // If we selected something without an id, it might be nested in
            // a group. Walk up the tree until we find an id.
            while (target && !target.id()) {
                target = target.parent;
            }

            // If they clicked on the background, deselect everything.
            if (!target || target === stage) {
                tr.nodes([]);
                props.labelManager.selectField(undefined);

                return;
            }

            const field = props.labelManager.current.value.fields?.find(f => f.guid === target?.id());

            if (!field) {
                console.error(`Could not find field '${target.id()}'.`);

                tr.nodes([]);
                props.labelManager.selectField(undefined);

                return;
            }

            // Select the node, only single selection supported.
            tr.nodes([target]);
            props.labelManager.selectField(field.guid);
        });

        stage.draw();
    });

    onBeforeUnmount(() => {
        stage?.destroy();
        stage = undefined;

        transformHelper?.destroy();
        transformHelper = undefined;
    });

    watch(props.labelManager.current, () => {
        if (stage) {
            stage.width(props.labelManager.current.value.width * pixelsPerInch);
            stage.height(props.labelManager.current.value.height * pixelsPerInch);
        }

        drawGridLines();
    });

    watch(() => props.showGrid, () => {
        drawGridLines();
    });

    watch(props.labelManager.current, () => {
        createOrUpdateNodes();
    });
</script>
