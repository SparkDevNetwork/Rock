<template>
    <div class="row">
        <div class="col-md-4">
            <div class="row">
                <div class="col-md-6">
                    <CheckBox label="Pending"
                              v-model="isPending" />
                </div>

                <div class="col-md-6">
                    <NumberUpDown label="Ability Level"
                                  v-model="abilityLevelNumber"
                                  help="Enter 0 for no selection."
                                  :min="0" />
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <NumberUpDown label="Area"
                                  v-model="areaNumber"
                                  :min="1" />
                </div>

                <div class="col-md-6">
                    <NumberUpDown label="Group"
                                  v-model="groupNumber"
                                  :min="1" />
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <NumberUpDown label="Location"
                                  v-model="locationNumber"
                                  :min="1" />
                </div>

                <div class="col-md-6">
                    <NumberUpDown label="Schedule"
                                  v-model="scheduleNumber"
                                  :min="1" />
                </div>
            </div>
        </div>

        <div v-if="attendance" class="col-md-8">
            <div v-if="attendance.messages && attendance.messages.length > 0">
                <div>Messages:</div>

                <ul>
                    <li v-for="msg in attendance.messages">{{ msg }}</li>
                </ul>
            </div>

            <div v-if="attendance.attendances && attendance.attendances.length > 0">
                <div>Attendance:</div>

                <ul>
                    <li v-for="item in attendance.attendances">
                        {{ item.attendance?.fullName }}
                        <ul>
                            <li>Status: {{ getCheckInStatus(item.attendance?.status) }}</li>
                            <li>Area: {{ item.attendance?.area?.name }}</li>
                            <li>Group: {{ item.attendance?.group?.name }}</li>
                            <li>Location: {{ item.attendance?.location?.name }}</li>
                            <li>Schedule: {{ item.attendance?.schedule?.name }}</li>

                            <li v-if="item.previouslyCompletedAchievements && item.previouslyCompletedAchievements.length > 0">
                                Previously Completed Achievements

                                <ul>
                                    <AchievementListItem v-for="achievement in item.previouslyCompletedAchievements"
                                                         :achievement="achievement" />
                                </ul>
                            </li>

                            <li v-if="item.inProgressAchievements && item.inProgressAchievements.length > 0">
                                In Progress Achievements

                                <ul>
                                    <AchievementListItem v-for="achievement in item.inProgressAchievements"
                                                         :achievement="achievement" />
                                </ul>
                            </li>

                            <li v-if="item.justCompletedAchievements && item.justCompletedAchievements.length > 0">
                                Just Completed Achievements

                                <ul>
                                    <AchievementListItem v-for="achievement in item.justCompletedAchievements"
                                                         :achievement="achievement" />
                                </ul>
                            </li>
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</template>

<script setup lang="ts">
    import { PropType } from "vue";
    import CheckBox from "@Obsidian/Controls/checkBox.obs";
    import NumberUpDown from "@Obsidian/Controls/numberUpDown.obs";
    import AchievementListItem from "./achievementListItem.partial.obs";
    import { useVModelPassthrough } from "@Obsidian/Utility/component";
    import { CheckInResultBag } from "@Obsidian/ViewModels/CheckIn/checkInResultBag";
    import { CheckInStatus, CheckInStatusDescription } from "@Obsidian/Enums/Event/checkInStatus";

    const props = defineProps({
        abilityLevelNumber: {
            type: Number as PropType<number>,
            required: true
        },

        areaNumber: {
            type: Number as PropType<number>,
            required: true
        },

        groupNumber: {
            type: Number as PropType<number>,
            required: true
        },

        locationNumber: {
            type: Number as PropType<number>,
            required: true
        },

        scheduleNumber: {
            type: Number as PropType<number>,
            required: true
        },

        isPending: {
            type: Boolean as PropType<boolean>,
            required: true
        },

        attendance: {
            type: Object as PropType<CheckInResultBag>,
            required: false
        }
    });

    const emit = defineEmits<{
        (event: "update:abilityLevelNumber", value: number): void;
        (event: "update:areaNumber", value: number): void;
        (event: "update:groupNumber", value: number): void;
        (event: "update:locationNumber", value: number): void;
        (event: "update:scheduleNumber", value: number): void;
        (event: "update:isPending", value: boolean): void;
    }>();

    const abilityLevelNumber = useVModelPassthrough(props, "abilityLevelNumber", emit);
    const areaNumber = useVModelPassthrough(props, "areaNumber", emit);
    const groupNumber = useVModelPassthrough(props, "groupNumber", emit);
    const locationNumber = useVModelPassthrough(props, "locationNumber", emit);
    const scheduleNumber = useVModelPassthrough(props, "scheduleNumber", emit);
    const isPending = useVModelPassthrough(props, "isPending", emit);

    function getCheckInStatus(status?: CheckInStatus): string {
        if (status === undefined) {
            return "Unknown";
        }

        if (status in CheckInStatusDescription) {
            return CheckInStatusDescription[status];
        }

        return "Unknown";
    }
</script>
