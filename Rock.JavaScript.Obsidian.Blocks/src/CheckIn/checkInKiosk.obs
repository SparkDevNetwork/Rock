}

.check-in-page .page-body .body-transition-container {
    position: absolute;
    width: 100%;
    height: 100%;
}

.check-in-page .page-body .scrollable-container {
    /*
     * When a scrollable is nested inside a flex, the entire tree must be flex.
     * Additionally, the min-height is required to make the scroll trigger
     * without having to put overflow: hidden on parent controls. Using overflow
     * would cause other issues where shadows and such get cropped.
     */
    display: flex;
    flex-direction: column;
    min-height: 0;
}

.check-in-page .scrollable {
    overflow-y: auto !important;
}

.check-in-page .page-body .check-in-panel {
