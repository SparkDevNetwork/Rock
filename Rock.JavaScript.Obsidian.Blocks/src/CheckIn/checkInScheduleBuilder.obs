                    <div class="grid-badges mr-3">
                        <span class="label label-default">
                            <!-- TODO: Handle singular 1 -->
                            <span class="label-value" v-if="scheduledGroupLocations.length > 0">{{ scheduledGroupLocations.length }} Schedule Locations</span>
                        </span>
                    </div>
                </div>
                <div class="grid-column-heading">
                    <div class="grid-column-header" style="flex: 1 1 30%">
                        <div class="grid-column-title">
                            Group
                        </div>
                    </div>
                    <div class="grid-column-header" style="flex: 1 1 30%">
                        <div class="grid-column-title">
                            Location
                        </div>
                    </div>
                    <div class="grid-column-header" style="flex: 1 1 1%" v-for="schedule in schedules">
                        <div class="grid-column-title" v-html="getScheduleHtml(schedule)"></div>
                    </div>
                </div>
            </div>

            <div class="grid-body">
                <div v-for="(scheduledGroupLocation, index) in scheduledGroupLocations" :class="['grid-row', isEven(index + 1) ? 'grid-row-even' : 'grid-row-odd']">
                    <div class="grid-cell" style="flex: 1 1 30%">
                        <div class="d-flex flex-column">
                            <div>{{ scheduledGroupLocation.groupName }}</div>
                            <small>{{ scheduledGroupLocation.groupPath }}</small>
                        </div>
                    </div>

                    <div class="grid-cell" style="flex: 1 1 30%">
                        <div class="d-flex flex-column">
                            <div>{{ scheduledGroupLocation.locationName }}</div>
                            <small>{{ scheduledGroupLocation.locationPath }}</small>
                        </div>
                    </div>

                    <div v-for="schedule in schedules" class="grid-cell" style="flex: 1 1 1%">
                        <InlineCheckBox label=""
                                        :modelValue="isScheduleEnabled(scheduledGroupLocation, schedule)"
                                        @update:modelValue="onScheduleClick(scheduledGroupLocation, schedule)" />
                    </div>
                </div>
            </div>
        </div>
    <!-- </Panel> -->
