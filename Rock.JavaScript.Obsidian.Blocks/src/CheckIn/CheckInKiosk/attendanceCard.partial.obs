<template>
    <div class="attendance-card well" style="width: calc(33.33% - calc(var(--item-spacing) * 2 / 3))">
        <div class="title" style="display: flex; gap: var(--item-spacing); justify-content: center; align-items: center;">
            <div class="avatar" :style="avatarStyle"></div>

            <div class="name">{{ attendance.attendance?.person?.fullName }}</div>
        </div>

        <label>Checked Into</label>

        <div class="label label-info" style="display: flex;">
            <div>{{ attendance.attendance?.location?.name }}</div>
            <div style="margin-left: auto;">{{ attendance.attendance?.schedule?.name }}</div>
        </div>

        <div v-if="attendance.inProgressAchievements" class="achievements" style="margin-top: var(--item-spacing);">
            <label>Current Achievement Status</label>

            <div v-for="achievement in attendance.inProgressAchievements">
                <div class="title" style="display: flex;">
                    <div style="font-weight: bold;">{{ achievement.name }}</div>
                    <div style="margin-left: auto;">{{ getPercentComplete(achievement) }}</div>
                </div>
                <div class="progress">
                    <div class="progress-bar" role="progressbar" :style="{ width: getPercentComplete(achievement) }"></div>
                </div>
            </div>
        </div>
    </div>
</template>

<script setup lang="ts">
    import { AchievementBag } from "@Obsidian/ViewModels/CheckIn/achievementBag";
    import { RecordedAttendanceBag } from "@Obsidian/ViewModels/CheckIn/recordedAttendanceBag";
    import { computed, CSSProperties, DeepReadonly, PropType } from "vue";

    const props = defineProps({
        attendance: {
            type: Object as PropType<DeepReadonly<RecordedAttendanceBag>>,
            required: true
        }
    });

    const avatarStyle = computed((): CSSProperties => {
        const properties: CSSProperties = {
            backgroundImage: `url("${props.attendance.attendance?.person?.photoUrl}")`
        };

        return properties;
    });

    function getPercentComplete(achievement: AchievementBag): string {
        return `${Math.floor(achievement.progress * 100)}%`;
    }
</script>
