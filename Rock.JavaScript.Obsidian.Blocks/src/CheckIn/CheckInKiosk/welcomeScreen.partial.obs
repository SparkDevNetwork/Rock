<!-- Copyright by the Spark Development Network; Licensed under the Rock Community License -->
<template>
    <div class="welcome-screen">
        <div class="promotion">
        </div>

        <div class="start-button">
            <RockButton btnType="primary"
                        @click="onStartClick">
                Start
            </RockButton>
        </div>

        <div class="scan-barcode-button">
            <RockButton id="barcode-button" btnType="default">
                <div class="title"><i class="fa fa-qrcode"></i></div>
                <div class="subtitle">Scan A Barcode</div>
            </RockButton>
        </div>
    </div>
</template>

<script setup lang="ts">
    import RockButton from "@Obsidian/Controls/rockButton.obs";
    import { Html5Qrcode } from "@Obsidian/Libs/html5-qrcode";
    import { KioskConfigurationBag } from "@Obsidian/ViewModels/CheckIn/kioskConfigurationBag";
    import { onMounted, PropType } from "vue";

    const props = defineProps({
        configuration: {
            type: Object as PropType<KioskConfigurationBag>,
            required: true
        }
    });

    const emit = defineEmits<{
        (event: "start"): void;
    }>();

    function onStartClick(): void {
        emit("start");
    }

    onMounted(async () => {
        if (props.configuration.kiosk?.isCameraEnabled) {
            const scanner = new Html5Qrcode("barcode-button");
            const deviceId = (await Html5Qrcode.getCameras())[0].id;

            scanner.start(deviceId, {
                fps: 10,
                aspectRatio: 4/3,
                qrbox: {
                    width: 250,
                    height: 250
                }
            }, (decodedText) => {
                console.log("SCAN", decodedText);
            }, (_errorMessage) => {
                // Ignore it, probably a partial read.
            });
        }
    });
</script>
