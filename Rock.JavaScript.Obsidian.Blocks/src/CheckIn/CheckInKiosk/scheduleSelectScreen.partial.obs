<template>
    <div class="schedule-select-screen">
        <MainPanel :title="title"
                   :subtitle="subtitle"
                   :person="session.currentAttendee?.person">
            <div class="button-list">
                <RockButton v-for="schedule in schedules"
                            btnType="primary"
                            class="schedule-button"
                            @click="onScheduleClick(schedule)">
                    <div class="selection">
                        <i v-if="isSelected(schedule)" class="fa fa-check-square"></i>
                        <i v-else class="fa fa-square-o"></i>
                    </div>

                    <div class="title">{{ schedule.name }}</div>
                </RockButton>
            </div>
        </MainPanel>
    </div>
</template>

<script setup lang="ts">
    import MainPanel from "./mainPanel.partial.obs";
    import RockButton from "@Obsidian/Controls/rockButton.obs";
    import { computed, DeepReadonly, PropType, ref, watch } from "vue";
    import { KioskConfigurationBag } from "@Obsidian/ViewModels/Blocks/CheckIn/CheckInKiosk/kioskConfigurationBag";
    import { alert } from "@Obsidian/Utility/dialogs";
    import { CheckInSession } from "./checkInSession.partial";
    import { isGuidInList, KioskButton, UnexpectedErrorMessage } from "./utils.partial";
    import { ScheduleOpportunityBag } from "@Obsidian/ViewModels/CheckIn/scheduleOpportunityBag";
    import { KioskCheckInMode } from "@Obsidian/Enums/CheckIn/kioskCheckInMode";
    import { Guid } from "@Obsidian/Types";
    import { CheckInItemBag } from "@Obsidian/ViewModels/CheckIn/checkInItemBag";
    import { areEqual } from "@Obsidian/Utility/guid";

    const props = defineProps({
        configuration: {
            type: Object as PropType<KioskConfigurationBag>,
            required: true
        },

        session: {
            type: Object as PropType<CheckInSession>,
            required: true
        }
    });

    const emit = defineEmits<{
        (event: "next", session: CheckInSession): void;
        (event: "updateActions", actions: KioskButton[]): void;
    }>();

    // #region Values

    const selections = ref<Guid[]>(getDefaultSelections(props.session.currentOpportunitySelection?.schedules));

    // #endregion

    // #region Computed Values

    const title = computed((): string => {
        if (props.configuration.template?.kioskCheckInType === KioskCheckInMode.Family) {
            return "Select Times";
        }
        else {
            return props.session.currentOpportunitySelection?.location?.name ?? "Schedule";
        }
    });

    const subtitle = computed((): string => {
        if (props.configuration.template?.kioskCheckInType === KioskCheckInMode.Family) {
            return `Select your preferred check-in times`;
        }
        else {
            return `Select the times you would like to check ${props.session.currentAttendee?.person?.nickName} into`;
        }
    });

    const schedules = computed((): ScheduleOpportunityBag[] => {
        return props.session.getAvailableSchedules();
    });

    // #endregion

    // #region Functions

    function getDefaultSelections(schedule: DeepReadonly<CheckInItemBag> | DeepReadonly<CheckInItemBag[]> | undefined | null): Guid[] {
        // DeepReadonly and Array.isArray() don't play well together. So force
        // a cast back to the native object.
        const item = schedule as CheckInItemBag | CheckInItemBag[] | undefined | null;

        if (!item) {
            return [];
        }
        else if (Array.isArray(item)) {
            return item.map(s => s.guid);
        }
        else {
            return [item.guid];
        }
    }

    function isSelected(schedule: DeepReadonly<CheckInItemBag>): boolean {
        return selections.value.some(s => areEqual(s, schedule.guid));
    }

    /**
     * Update the actions supported by this screen.
     */
    function updateActions(): void {
        const actions: KioskButton[] = [];

        actions.push({
            type: "primary",
            title: "Next",
            key: "next",
            disabled: selections.value.length === 0,
            handler: onNextClick
        });

        emit("updateActions", actions);
    }

    function onScheduleClick(schedule: DeepReadonly<CheckInItemBag>): void {
        if (isGuidInList(schedule.guid, selections.value)) {
            selections.value = selections.value.filter(s => !areEqual(s, schedule.guid));
        }
        else {
            selections.value = [schedule.guid, ...selections.value];
        }
    }

    /**
     * Handles the click event for an next button.
     */
    async function onNextClick(): Promise<void> {
        try {
            const scheduleGuids = schedules.value
                .filter(s => isGuidInList(s.guid, selections.value))
                .map(s => s.guid);

            const newSession = props.session.withSelectedSchedules(scheduleGuids);

            emit("next", await newSession.withNextScreen());
        }
        catch (error) {
            await alert(error instanceof Error ? error.message : UnexpectedErrorMessage);
        }
    }

    // #endregion

    watch(selections, () => updateActions());

    updateActions();
</script>
