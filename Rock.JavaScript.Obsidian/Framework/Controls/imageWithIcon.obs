<template>
    <div ref="container" class="image-with-icon-container">
        <img :src="imgSrc" />
        <span :class="stackClass" style="position: relative; bottom: 1.33em; left: .5em; text-align: center;">
            <i class="fa fa-circle fa-stack-2x" :style="lightenedStyle"></i>
            <i :style="'color: ' + highlightColor" :class="iconCssClass + ' fa-stack-1x'"></i>
        </span>
    </div>
</template>

<script setup lang="ts">
    import { Guid } from "@Obsidian/Types";
    import { PropType, computed, ref } from "vue";

    const props = defineProps({
        /** The Guid of the Image file to show. */
        imageFileGuid: {
            type: String as PropType<Guid>,
            default: ""
        },

        /** The scale of the font-awesome icon (defaults to 3). */
        iconSize: {
            type: Number as PropType<number>,
            default: 3
        },

        /** The font-awesome icon css class to use. */
        iconCssClass: {
            type: String as PropType<string>,
            default: ""
        },

        /** The color for the icon. */
        highlightColor: {
            type: String as PropType<string>,
            default: ""
        },

        /** Whether to lighten the circular background badge (stacked) icon. Defaults to true. */
        lightenStackColor: {
            type: Boolean as PropType<boolean>,
            default: true
        },
    });

    // #region Values

    const validGuidLength = 36;
    const imageFileGuid = ref<string>(props?.imageFileGuid?.toString() ?? "");
    const iconCssClass = ref<string>(props?.iconCssClass ?? "");
    const highlightColor = ref<string>(props?.highlightColor ?? "");

    // The scale of the stacked icon.
    const iconSize = ref<number>(props?.iconSize ?? 3);

    // The containing element for getting the image with the proper width.
    const container = ref<HTMLElement | null>();

    // #endregion

    // #region Computed Values

    const guidIsValid = computed(() => props.imageFileGuid?.length === validGuidLength);

    const imgSrc = computed(() =>
        guidIsValid.value ?
            `/GetImage.ashx?guid=${imageFileGuid.value}&maxwidth=${container.value?.clientWidth}` :
            "/Assets/Images/no-picture.svg?");

    const stackClass = computed(() => `fa-stack fa-${iconSize.value}x`);

    const lightenedStyle = computed(() => props.lightenStackColor ? `color: oklch(from ${highlightColor.value} calc(l + .33) c h);` : undefined);

    // #endregion

</script>
